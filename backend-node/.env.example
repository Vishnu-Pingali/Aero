# ==============================================================================
# Aero Ops Intelligence — Node Backend Environment Variables
# Copy this file to `.env` in the same directory and configure the variables.
# ==============================================================================

# ── Application Configuration ──────────────────────────────────────────────────
# Deployment mode: 'development' | 'production'
ENVIRONMENT=production
# Log verbosity level: 'error' | 'warn' | 'info' | 'debug'
LOG_LEVEL=info
# Port to run the Express server on
PORT=8000
# Comma-separated list of allowed origins for CORS (leave empty for default localhost origins)
# Example: http://localhost:5173,https://my-dashboard.example.com
CORS_ORIGINS=

# ── AirLabs API Configuration ──────────────────────────────────────────────────
# Your API key from airlabs.co (can also be loaded from credentials.json)
AIRLABS_API_KEY=
# Path to credentials.json file containing the key (defaults to ./credentials/credentials.json)
AIRLABS_CREDENTIALS_PATH=
# AirLabs API endpoint URL
AIRLABS_BASE_URL=https://airlabs.co/api/v9
# Duration (in seconds) to cache flight coordinates responses (e.g., 600 = 10 minutes)
AIRLABS_CACHE_TTL_SECONDS=600
# Request timeout (in seconds) when polling AirLabs endpoints
AIRLABS_TIMEOUT_SECONDS=30
# Rate limit safety: minimum interval (in seconds) between consecutive API requests
AIRLABS_MIN_REQUEST_INTERVAL_SECONDS=600

# ── Weather API Configuration ──────────────────────────────────────────────────
# Duration (in seconds) to cache METAR and SIGMET weather advisories (default: 60s)
WEATHER_CACHE_TTL_SECONDS=60
# Request timeout (in seconds) when querying AviationWeather.gov
WEATHER_TIMEOUT_SECONDS=20

